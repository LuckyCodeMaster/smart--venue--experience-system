# ── Smart Venue Experience System — Environment Variables ──────────────────────
#
# Copy this file to .env and fill in the values for your environment.
# Never commit the actual .env file (it is already listed in .gitignore).
#
# Deployment targets:
#   Backend  → Render  (set these vars in the Render dashboard)
#   Frontend → Vercel  (set these vars in the Vercel dashboard)
#   Local    → Docker Compose reads from a .env file at the project root
# ────────────────────────────────────────────────────────────────────────────────

# ── Backend (Render / Docker) ───────────────────────────────────────────────────

# Node environment: "development" or "production"
NODE_ENV=development

# Port the Express server listens on
PORT=5000

# Comma-separated list of frontend origins allowed by CORS.
# Development:  http://localhost:3000
# Production:   https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Vercel / Docker build arg) ───────────────────────────────────────

# Base URL of the backend API used by the React app.
# Local Docker stack: http://localhost:5000
# Production:         https://sves-backend.onrender.com
REACT_APP_BACKEND_URL=http://localhost:5000
