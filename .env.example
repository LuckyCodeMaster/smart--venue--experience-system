# =============================================================================
# Smart Venue Experience System (SVES) — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the actual .env file to version control.
# =============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000

# ----------------------------------------------------------------------------
# PostgreSQL Database
# ----------------------------------------------------------------------------
# Full connection string (used by Prisma / Sequelize / pg)
DATABASE_URL=postgresql://sves:sves_password@localhost:5432/sves_db

# Individual connection parameters (used by Docker Compose and some drivers)
PG_HOST=localhost
PG_PORT=5432
PG_USER=sves
PG_PASSWORD=sves_password
PG_DATABASE=sves_db

# ----------------------------------------------------------------------------
# Redis Cache & Pub/Sub
# ----------------------------------------------------------------------------
REDIS_URL=redis://:redis_password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ----------------------------------------------------------------------------
# JSON Web Tokens
# ----------------------------------------------------------------------------
# Must be at least 32 characters. Use a cryptographically random string.
JWT_SECRET=change_me_in_production_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_in_production_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# CORS & URLs
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api/v1
REACT_APP_WS_URL=http://localhost:5000

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Options: error | warn | info | http | debug | silly
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# IoT / Sensor Security
# ----------------------------------------------------------------------------
# SHA-256 hash of the API key that IoT sensor devices use to authenticate.
# Generate with: echo -n "your_sensor_key" | sha256sum
# Store the RAW key only on the IoT devices, never in this file in production.
SENSOR_API_KEY_HASH=

# ----------------------------------------------------------------------------
# Optional: Email (SMTP) — for notifications and account verification
# ----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=no-reply@example.com
# SMTP_PASS=smtp_password
# SMTP_FROM="SVES <no-reply@example.com>"

# ----------------------------------------------------------------------------
# Optional: Push Notifications
# ----------------------------------------------------------------------------
# FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key
# APNS_KEY_ID=your_apple_push_key_id
# APNS_TEAM_ID=your_apple_team_id

# ----------------------------------------------------------------------------
# Optional: Cloud Storage (for venue maps / images)
# ----------------------------------------------------------------------------
# S3_BUCKET=sves-assets
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key

# ----------------------------------------------------------------------------
# Required GitHub Actions Secrets (configure in repo Settings → Secrets)
# ----------------------------------------------------------------------------
# REACT_APP_API_URL  — Public URL of the backend API (e.g. https://api.example.com/api/v1)
# REACT_APP_WS_URL   — Public WebSocket URL          (e.g. https://api.example.com)
# PRODUCTION_URL     — Public URL of the deployed app (used as the environment link in deploy.yml)
