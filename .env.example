# Smart Venue Experience System — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# ── Backend ────────────────────────────────────────────────────────────────────

# Node environment: development | production
NODE_ENV=production

# Port the Express server listens on (Render sets this automatically)
PORT=5000

# Comma-separated list of allowed CORS origins for the API.
# Example: https://sves-demo.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ───────────────────────────────────────────────────────────────────

# Public URL of the backend API consumed by the React app at build time.
# Set this in your Vercel project settings or CI environment.
REACT_APP_BACKEND_URL=http://localhost:5000
