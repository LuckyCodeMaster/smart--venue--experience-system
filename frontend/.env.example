# ─── Application ─────────────────────────────────────────────────────────────

# Backend API base URL
REACT_APP_API_URL=http://localhost:3000/api/v1

# WebSocket server URL (can be same as API)
REACT_APP_WS_URL=http://localhost:3000

# ─── Feature Flags ───────────────────────────────────────────────────────────

# Enable/disable real-time WebSocket updates (true/false)
REACT_APP_ENABLE_WEBSOCKET=true

# ─── Maps / Navigation ───────────────────────────────────────────────────────

# Google Maps API key (for indoor navigation integration)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# HERE Maps API key (alternative to Google Maps)
REACT_APP_HERE_MAPS_API_KEY=your_here_maps_api_key_here

# ─── Analytics ───────────────────────────────────────────────────────────────

# Optional: analytics tracking ID
REACT_APP_ANALYTICS_ID=

# ─── Environment ─────────────────────────────────────────────────────────────

# Set to 'development' or 'production'
NODE_ENV=development
