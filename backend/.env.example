# Application
NODE_ENV=development
PORT=3000

# Database (use DATABASE_URL or individual vars)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sves_db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sves_db
# DB_USER=postgres
# DB_PASSWORD=password
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-in-prod
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12
SENSOR_API_KEY_SALT=your-sensor-api-key-salt-change-in-prod

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# Logging
LOG_LEVEL=info
LOG_DIR=logs
